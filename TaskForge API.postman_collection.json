    {
      "name": "02. Teams (Команды)",
      "item": [
        {
          "name": "Create Team",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "var teamId = \"\";",
                  "",
                  "// Поиск team_id в разных структурах",
                  "if (jsonData.data && jsonData.data.id) {",
                  "    teamId = jsonData.data.id;",
                  "} else if (jsonData.id) {",
                  "    teamId = jsonData.id;",
                  "} else if (jsonData.data && jsonData.data.team_id) {",
                  "    teamId = jsonData.data.team_id;",
                  "}",
                  "",
                  "pm.test(\"Team ID is present\", function () {",
                  "    pm.expect(teamId).to.not.be.empty;",
                  "});",
                  "",
                  "if (teamId) {",
                  "    pm.environment.set(\"team_id\", teamId);",
                  "    console.log(\"✅ Team ID saved: \" + teamId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test Team {{randomInt}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/teams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "teams"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get My Teams",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "var teams = [];",
                  "",
                  "if (jsonData.data && Array.isArray(jsonData.data)) {",
                  "    teams = jsonData.data;",
                  "} else if (Array.isArray(jsonData)) {",
                  "    teams = jsonData;",
                  "}",
                  "",
                  "if (teams.length > 0) {",
                  "    console.log(\"✅ Found \" + teams.length + \" teams\");",
                  "    // Если team_id еще не установлен, берем из первой команды",
                  "    if (!pm.environment.get(\"team_id\")) {",
                  "        pm.environment.set(\"team_id\", teams[0].id);",
                  "        console.log(\"✅ Team ID set from list: \" + teams[0].id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/teams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "teams"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Invite User to Team",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201 or 200\", function () {",
                  "    pm.response.to.have.status.oneOf([200, 201]);",
                  "});",
                  "console.log(\"✅ User invited to team\");"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Проверка наличия team_id",
                  "if (!pm.environment.get(\"team_id\")) {",
                  "    throw new Error(\"❌ team_id is not set. Please create a team first.\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"user_id\": {{user_id_2}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/teams/{{team_id}}/invite",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "teams",
                "{{team_id}}",
                "invite"
              ]
            }
          },
          "response": []
        }
      ]
