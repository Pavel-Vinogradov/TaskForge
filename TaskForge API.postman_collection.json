  "item": [
    {
      "name": "01. Auth (Аутентификация)",
      "item": [
        {
          "name": "Register User 1 (Owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 or 201\", function () {",
                  "    pm.response.to.have.status.oneOf([200, 201]);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "var token = \"\";",
                  "",
                  "// Поиск токена в разных структурах ответа",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    token = jsonData.data.token;",
                  "} else if (jsonData.token) {",
                  "    token = jsonData.token;",
                  "} else if (jsonData.data && jsonData.data.user_id) {",
                  "    // Если токен не вернулся, пробуем логин следующим шагом",
                  "    console.log(\"Registration successful, token will be retrieved via login\");",
                  "}",
                  "",
                  "if (token) {",
                  "    pm.environment.set(\"token\", token);",
                  "    console.log(\"✅ Token saved: \" + token);",
                  "}",
                  "",
                  "// Сохранение ID текущего пользователя если есть",
                  "if (jsonData.data && jsonData.data.user_id) {",
                  "    pm.environment.set(\"user_id_1\", jsonData.data.user_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"owner{{randomInt}}@example.com\",\n    \"password\": \"password123\",\n    \"username\": \"Owner{{randomInt}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login User 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "var token = \"\";",
                  "",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    token = jsonData.data.token;",
                  "} else if (jsonData.token) {",
                  "    token = jsonData.token;",
                  "}",
                  "",
                  "pm.test(\"Token is present\", function () {",
                  "    pm.expect(token).to.not.be.empty;",
                  "});",
                  "",
                  "if (token) {",
                  "    pm.environment.set(\"token\", token);",
                  "    console.log(\"✅ Token updated: \" + token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"owner{{randomInt}}@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "login"
              ]
            }
          },
          "response": []
