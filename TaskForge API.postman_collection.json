    {
      "name": "03. Tasks (Задачи)",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "var taskId = \"\";",
                  "",
                  "// Поиск task_id в разных структурах",
                  "if (jsonData.data && jsonData.data.id) {",
                  "    taskId = jsonData.data.id;",
                  "} else if (jsonData.id) {",
                  "    taskId = jsonData.id;",
                  "} else if (jsonData.Data && jsonData.Data.id) {",
                  "    taskId = jsonData.Data.id;",
                  "}",
                  "",
                  "pm.test(\"Task ID is present\", function () {",
                  "    pm.expect(taskId).to.not.be.empty;",
                  "});",
                  "",
                  "if (taskId) {",
                  "    pm.environment.set(\"task_id\", taskId);",
                  "    console.log(\"✅ Task ID saved: \" + taskId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.environment.get(\"team_id\")) {",
                  "    throw new Error(\"❌ team_id is not set. Please create a team first.\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Task {{randomInt}}\",\n    \"description\": \"Auto-generated task\",\n    \"team_id\": {{team_id}},\n    \"assignee_id\": {{user_id_2}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks"
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "var tasks = [];",
                  "",
                  "if (jsonData.data && jsonData.data.Data && Array.isArray(jsonData.data.Data)) {",
                  "    tasks = jsonData.data.Data;",
                  "} else if (jsonData.Data && Array.isArray(jsonData.Data)) {",
                  "    tasks = jsonData.Data;",
                  "} else if (jsonData.data && Array.isArray(jsonData.data)) {",
                  "    tasks = jsonData.data;",
                  "}",
                  "",
                  "console.log(\"✅ Found \" + tasks.length + \" tasks\");",
                  "",
                  "// Если task_id еще не установлен, берем из первого элемента",
                  "if (tasks.length > 0 && !pm.environment.get(\"task_id\")) {",
                  "    pm.environment.set(\"task_id\", tasks[0].id);",
                  "    console.log(\"✅ Task ID set from list: \" + tasks[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "team_id",
                  "value": "{{team_id}}",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "todo",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "console.log(\"✅ Task updated successfully\");"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.environment.get(\"task_id\")) {",
                  "    throw new Error(\"❌ task_id is not set. Please create a task first.\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"in_progress\",\n    \"title\": \"Task {{randomInt}} (Updated)\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks/{{task_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks",
                "{{task_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Task History",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "var history = [];",
                  "",
                  "if (jsonData.data && Array.isArray(jsonData.data)) {",
                  "    history = jsonData.data;",
                  "} else if (jsonData.data && jsonData.data.Data && Array.isArray(jsonData.data.Data)) {",
                  "    history = jsonData.data.Data;",
                  "}",
                  "",
                  "console.log(\"✅ History records found: \" + history.length);",
                  "",
                  "if (history.length > 0) {",
                  "    pm.test(\"History is not empty\", function () {",
                  "        pm.expect(history.length).to.be.above(0);",
                  "    });",
                  "    console.log(\"✅ Last change: \" + history[history.length - 1].field);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.environment.get(\"task_id\")) {",
                  "    throw new Error(\"❌ task_id is not set.\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks/{{task_id}}/history",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks",
                "{{task_id}}",
                "history"
              ]
            }
          },
          "response": []
        }
      ]
